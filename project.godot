config_version=5

[application]

config/name="whispers"
config/description="A first-person 3D psychological horror adventure about a forest that collects voices."
config/features=PackedStringArray("4.3", "Forward Plus")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[rendering]

anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.07, 0.07, 0.08, 1)
